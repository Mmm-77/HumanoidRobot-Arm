<?xml version="1.0"?>
<robot name="humanoid_arm">
  <material name="base_blue"><color rgba="0.10 0.20 0.45 1.0"/></material>
  <material name="link_silver"><color rgba="0.65 0.70 0.75 1.0"/></material>
  <material name="tool_orange"><color rgba="0.95 0.35 0.08 1.0"/></material>
  <material name="joint_red"><color rgba="0.85 0.15 0.15 1.0"/></material>

  <link name="world"/>

  <link name="base_link">
    <inertial><origin xyz="0 0 -0.015"/><mass value="1.0"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 -0.015"/><geometry><cylinder radius="0.04" length="0.03"/></geometry><material name="base_blue"/></visual>
    <collision><origin xyz="0 0 -0.015"/><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
  </link>

  <joint name="world_joint" type="fixed">
    <parent link="world"/><child link="base_link"/>
    <origin xyz="0 0 0" rpy="1.047197551 0 0"/>
  </joint>

  <link name="link_1">
    <inertial><origin xyz="0 -0.025 0"/><mass value="0.20"/><inertia ixx="0.000043" ixy="0" ixz="0" iyy="0.0000036" iyz="0" izz="0.000043"/></inertial>
    <visual><origin xyz="0 -0.025 0" rpy="1.57079632679 0 0"/><geometry><cylinder radius="0.006" length="0.05"/></geometry><material name="link_silver"/></visual>
    <visual><geometry><cylinder radius="0.008" length="0.02"/></geometry><material name="joint_red"/></visual>
    <collision><origin xyz="0 -0.025 0" rpy="1.57079632679 0 0"/><geometry><cylinder radius="0.006" length="0.05"/></geometry></collision>
  </link>
  <link name="link_2">
    <inertial><origin xyz="0 0 -0.035"/><mass value="0.18"/><inertia ixx="0.000075" ixy="0" ixz="0" iyy="0.000075" iyz="0" izz="0.0000032"/></inertial>
    <visual><origin xyz="0 0 -0.035"/><geometry><cylinder radius="0.006" length="0.07"/></geometry><material name="link_silver"/></visual>
    <visual><origin rpy="0 1.57079632679 0"/><geometry><cylinder radius="0.008" length="0.02"/></geometry><material name="joint_red"/></visual>
    <collision><origin xyz="0 0 -0.035"/><geometry><cylinder radius="0.006" length="0.07"/></geometry></collision>
  </link>
  <link name="link_3">
    <inertial><origin xyz="0 0 -0.0175"/><mass value="0.14"/><inertia ixx="0.000015" ixy="0" ixz="0" iyy="0.000015" iyz="0" izz="0.0000021"/></inertial>
    <visual><origin xyz="0 0 -0.0175"/><geometry><cylinder radius="0.0055" length="0.035"/></geometry><material name="link_silver"/></visual>
    <visual><geometry><cylinder radius="0.007" length="0.018"/></geometry><material name="joint_red"/></visual>
    <collision><origin xyz="0 0 -0.0175"/><geometry><cylinder radius="0.0055" length="0.035"/></geometry></collision>
  </link>
  <link name="link_4">
    <inertial><mass value="0.10"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00005"/></inertial>
    <visual><origin rpy="1.57079632679 0 0"/><geometry><cylinder radius="0.007" length="0.018"/></geometry><material name="joint_red"/></visual>
    <collision><geometry><sphere radius="0.009"/></geometry></collision>
  </link>
  <link name="tool_link">
    <inertial><mass value="0.05"/><inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/></inertial>
    <visual><geometry><sphere radius="0.006"/></geometry><material name="tool_orange"/></visual>
    <collision><geometry><sphere radius="0.006"/></geometry></collision>
  </link>
  <link name="end_rod">
    <inertial><origin xyz="0 0 -0.135"/><mass value="0.08"/><inertia ixx="0.00049" ixy="0" ixz="0" iyy="0.00049" iyz="0" izz="0.0000008"/></inertial>
    <visual><origin xyz="0 0 -0.135"/><geometry><cylinder radius="0.005" length="0.27"/></geometry><material name="link_silver"/></visual>
    <collision><origin xyz="0 0 -0.135"/><geometry><cylinder radius="0.005" length="0.27"/></geometry></collision>
  </link>
  <link name="tip_frame"/>

  <!--
    At zero position all link frames are parallel to base_link.  Consequently,
    each origin below is the vector from the preceding absolute joint point to
    the current one, expressed in the parent link frame.  Each axis is stated
    directly in the joint frame (which is base-aligned at zero position).
  -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.141592654" upper="3.141592654" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0 -0.05 0" rpy="-1.047197551 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-3.141592654" upper="3.141592654" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0 0 -0.07" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.141592654" upper="3.141592654" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin xyz="0 0 -0.035" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.141592654" upper="3.141592654" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="tool_joint" type="fixed"><parent link="link_4"/><child link="tool_link"/></joint>
  <joint name="rod_joint" type="fixed"><parent link="link_4"/><child link="end_rod"/></joint>
  <joint name="tip_joint" type="fixed"><parent link="end_rod"/><child link="tip_frame"/><origin xyz="0 0 -0.27" rpy="0 0 0"/></joint>

  <gazebo>
    <plugin name="humanoid_arm_joint_driver" filename="libhumanoid_arm_gazebo_joint_driver.so">
      <ros><namespace>/</namespace></ros>
      <command_topic>/kinematics/joint_command</command_topic>
      <state_topic>/kinematics/joint_state</state_topic>
      <direct_mode>false</direct_mode>
      <publish_rate_hz>60.0</publish_rate_hz>
    </plugin>
  </gazebo>
</robot>
