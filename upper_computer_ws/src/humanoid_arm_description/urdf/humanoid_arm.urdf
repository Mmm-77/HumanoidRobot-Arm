<?xml version="1.0"?>
<robot name="humanoid_arm">
  <material name="base_blue"><color rgba="0.10 0.20 0.45 1.0"/></material>
  <material name="link_silver"><color rgba="0.65 0.70 0.75 1.0"/></material>
  <material name="tool_orange"><color rgba="0.95 0.35 0.08 1.0"/></material>

  <link name="world"/>

  <link name="base_link">
    <inertial><origin xyz="0 0 0.015"/><mass value="1.0"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 0.015"/><geometry><cylinder radius="0.04" length="0.03"/></geometry><material name="base_blue"/></visual>
    <collision><origin xyz="0 0 0.015"/><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
  </link>

  <joint name="world_joint" type="fixed">
    <parent link="world"/><child link="base_link"/>
  </joint>

  <link name="link_1">
    <inertial><mass value="0.20"/><inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><cylinder radius="0.012" length="0.05"/></geometry><material name="link_silver"/></visual>
    <collision><geometry><cylinder radius="0.012" length="0.05"/></geometry></collision>
  </link>
  <link name="link_2">
    <inertial><mass value="0.18"/><inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><cylinder radius="0.011" length="0.07"/></geometry><material name="link_silver"/></visual>
    <collision><geometry><cylinder radius="0.011" length="0.07"/></geometry></collision>
  </link>
  <link name="link_3">
    <inertial><mass value="0.14"/><inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00008"/></inertial>
    <visual><geometry><cylinder radius="0.010" length="0.07"/></geometry><material name="link_silver"/></visual>
    <collision><geometry><cylinder radius="0.010" length="0.07"/></geometry></collision>
  </link>
  <link name="link_4">
    <inertial><mass value="0.10"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00005"/></inertial>
    <visual><geometry><cylinder radius="0.009" length="0.035"/></geometry><material name="link_silver"/></visual>
    <collision><geometry><cylinder radius="0.009" length="0.035"/></geometry></collision>
  </link>
  <link name="tool_link">
    <inertial><mass value="0.05"/><inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/></inertial>
    <visual><geometry><sphere radius="0.015"/></geometry><material name="tool_orange"/></visual>
    <collision><geometry><sphere radius="0.015"/></geometry></collision>
  </link>

  <!-- Each origin implements RotX(alpha) TransX(a) TransZ(d), followed by RotZ(theta). -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0.002 0.003 0" rpy="-1.57079632679 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-1.483529864" upper="3.054326191" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0.0289 -0.05 0" rpy="1.57079632679 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.174532925" upper="2.617993878" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0 0.07 0" rpy="-1.57079632679 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-1.745329252" upper="1.745329252" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin xyz="0 -0.035 0" rpy="1.57079632679 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.698131701" upper="1.745329252" effort="10" velocity="3.141592654"/>
  </joint>
  <joint name="tool_joint" type="fixed"><parent link="link_4"/><child link="tool_link"/></joint>

  <gazebo>
    <plugin name="humanoid_arm_joint_driver" filename="libhumanoid_arm_gazebo_joint_driver.so">
      <ros><namespace>/</namespace></ros>
      <command_topic>/kinematics/joint_command</command_topic>
      <state_topic>/kinematics/joint_state</state_topic>
      <direct_mode>false</direct_mode>
      <publish_rate_hz>60.0</publish_rate_hz>
    </plugin>
  </gazebo>
</robot>
